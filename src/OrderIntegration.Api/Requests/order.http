@baseUrl = http://localhost:5095

### Create order - OK
POST {{baseUrl}}/api/v1/orders
Content-Type: application/json

{
  "externalOrderId": "EXT-10001",
  "customerName": "Juan Pérez",
  "customerEmail": "juan@email.com",
  "totalAmount": 15000,
  "currency": "ARS",
  "items": [
    {
      "productName": "Funda Magnética",
      "quantity": 2,
      "unitPrice": 5000
    },
    {
      "productName": "Vidrio Templado",
      "quantity": 1,
      "unitPrice": 5000
    }
  ]
}


